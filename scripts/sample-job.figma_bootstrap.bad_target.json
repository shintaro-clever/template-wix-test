{
  "job_type": "integration_hub.phase2.figma_bootstrap_from_repo",
  "goal": "Bootstrap Hub routes into Figma",
  "inputs": {
    "message": "figma bootstrap",
    "target_path": "vault/targets/NOPE",
    "repo_local_path": "vault/targets/test",
    "repo_url": "https://github.com/shintaro-clver/test",
    "figma_design_url": "https://www.figma.com/file/CutkQD2XudkCe8eJ1jDfkZ/Hub",
    "strategy": "routes_first",
    "frames": [
      {
        "name": "Home",
        "source_path": "README.md"
      },
      {
        "name": "App",
        "source_path": "src/index.js"
      }
    ]
  },
  "constraints": {
    "allowed_paths": [
      ".ai-runs/"
    ],
    "max_files_changed": 0,
    "no_destructive_ops": true
  },
  "acceptance_criteria": [
    "Figma bootstrap report is saved",
    "Nodes artifact lists generated frames"
  ],
  "provenance": {
    "issue": "",
    "operator": "operator"
  },
  "run_mode": "mcp",
  "output_language": "ja",
  "expected_artifacts": [
    {
      "name": "figma_bootstrap_report.json",
      "description": "Summary of bootstrap execution"
    },
    {
      "name": "figma_bootstrap_nodes.json",
      "description": "Extracted frame candidates"
    }
  ]
}