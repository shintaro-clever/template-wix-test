    "When noop mode is active (default), the target file is NOT modified.",
    "diff_summary and checks[0].reason reflect noop when no file changed."
  ],
  "provenance": {
    "issue": "https://github.com/example/repo/issues/21",
    "operator": "operator"
  },
  "run_mode": "local_stub",
  "output_language": "ja",
  "expected_artifacts": [
    {
      "name": "repo_patch_report.json",
      "description": "Summary of repo patch"
    }
  ]
}
