#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

PREFIX_TAG="web.1 |"

log() {
  echo "[dev] $*"
}

log "Running npm test..."
npm test

HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-3100}"

log "Starting server at http://${HOST}:${PORT}/jobs"
log "Example verification: curl -I http://${HOST}:${PORT}/jobs"

FIFO_PATH="$(mktemp -u)"
mkfifo "$FIFO_PATH"
SERVER_PID=""

cleanup() {
  if [[ -n "$SERVER_PID" ]]; then
    kill "$SERVER_PID" >/dev/null 2>&1 || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  rm -f "$FIFO_PATH"
}

trap cleanup INT TERM EXIT

HOST="$HOST" PORT="$PORT" node server.js > "$FIFO_PATH" 2>&1 &
SERVER_PID=$!

while IFS= read -r line || [[ -n "$line" ]]; do
  printf '%s %s\n' "$PREFIX_TAG" "$line"
done < "$FIFO_PATH"
