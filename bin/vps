#!/usr/bin/env bash
set -euo pipefail

HOST="${IH_VPS_HOST:-hubapp@210.131.210.190}"
KEY="${IH_VPS_KEY:-$HOME/.ssh/id_ed25519}"

exec ssh \
  -i "$KEY" \
  -o BatchMode=yes \
  -o IdentitiesOnly=yes \
  -o ServerAliveInterval=30 \
  -o ServerAliveCountMax=3 \
  -o ConnectTimeout=10 \
  -o StrictHostKeyChecking=accept-new \
  "$HOST" "$@"
